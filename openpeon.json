{
  "cesp_version": "1.0",
  "name": "stronghold-rat",
  "display_name": "The Rat (Stronghold Crusader)",
  "version": "1.0.0",
  "author": { "name": "Marko Jevic", "github": "koyev" },
  "license": "fair-use",
  "language": "en",
  "categories": {
    "session.start": {
      "sounds": [
        { "file": "sounds/rt_add_player.wav", "label": "Gasping" }
      ]
    },
    "task.acknowledge": {
      "sounds": [
        { "file": "sounds/rt_taunt_03.wav", "label": "Plans have been made" },
        { "file": "sounds/rt_taunt_05.wav", "label": "Forces of De Puce" }
      ]
    },
    "task.complete": {
      "sounds": [
        { "file": "sounds/rt_vict_01.wav", "label": "Ratty wins again" },
        { "file": "sounds/rt_vict_02.wav", "label": "Plans worked perfectly" },
        { "file": "sounds/rt_vict_04.wav", "label": "Glorious army triumphs" }
      ]
    },
    "task.error": {
      "sounds": [
        { "file": "sounds/rt_anger_01.wav", "label": "Troops didn't follow the plan" },
        { "file": "sounds/rt_anger_03.wav", "label": "Surrounded by idiots" },
        { "file": "sounds/rt_anger_04.wav", "label": "World has gone crazier" }
      ]
    },
    "input.required": {
      "sounds": [
        { "file": "sounds/rt_plead_01.wav", "label": "Don't hurt me" },
        { "file": "sounds/rt_plead_04.wav", "label": "No need to panic, Ratty" }
      ]
    },
    "resource.limit": {
      "sounds": [
        { "file": "sounds/rt_anger_02.wav", "label": "Oh bother, lost again" },
        { "file": "sounds/rt_plead_02.wav", "label": "It wasn't me" }
      ]
    },
    "user.spam": {
      "sounds": [
        { "file": "sounds/rt_taunt_01.wav", "label": "Impudent upstart" },
        { "file": "sounds/rt_taunt_07.wav", "label": "No use grovelling now" },
        { "file": "sounds/rt_kick_player.wav", "label": "Screaming" }
      ]
    }
  }
}
